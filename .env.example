# Copy to .env.local and fill in real values (never commit .env.local)

# Dashboard password for agent login
DASHBOARD_PASSWORD=your_secure_password

# Optional: OpenAI for WhatsApp paste parsing (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Optional: Outscraper — import from Google Maps (dashboard → Import from Outscraper)
OUTSCRAPER_API_KEY=

# Optional: Apify — import dataset as draft listings (dashboard → Import from Apify)
APIFY_API_TOKEN=

# Cloudinary — persistent images & video uploads on Vercel (https://cloudinary.com/console)
# If unset, uploads go to local public/uploads/ (dev only; not durable on serverless)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional folder prefix in Cloudinary Media Library (default: zanzibaba/listings)
# CLOUDINARY_FOLDER=zanzibaba/listings
